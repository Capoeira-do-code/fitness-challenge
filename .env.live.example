# Live Docker published ports
HTTP_PORT=80
HTTPS_PORT=443

# Container DB path used by app service
DB_PATH=/var/www/storage/fitness.sqlite
SEED_PASSWORD=
REQUEST_SCHEDULERS_ENABLED=0

# Optional fallback for in-app media search. Credentials can also be saved from
# Admin > Training. Google Custom Search only accepts existing eligible clients;
# YouTube requires YouTube Data API v3.
MEDIA_SEARCH_GOOGLE_API_KEY=
MEDIA_SEARCH_GOOGLE_CX=
MEDIA_SEARCH_YOUTUBE_API_KEY=
MEDIA_SEARCH_IMAGE_MAX_BYTES=8388608
